# Line Shark — Environment Variables
# Copy this to .env and fill in your API keys

# The Odds API (free tier: 500 req/month)
# Sign up: https://the-odds-api.com
ODDS_API_KEY=

# Firecrawl API
# Sign up: https://firecrawl.dev
FIRECRAWL_API_KEY=

# Anthropic Claude API
# Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Twitter/X API (optional — can use Firecrawl to scrape instead)
TWITTER_BEARER_TOKEN=

# Server
PORT=3001
